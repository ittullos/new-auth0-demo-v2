# Ignore real env files
/backend/.env
/frontend/.env

# Keep example env files tracked
!/backend/.env.example
!/frontend/.env.example

# OS/editor noise
.DS_Store
.vscode/
.idea/

# Ruby
/backend/.bundle/
/backend/vendor/bundle/

# Node
/frontend/node_modules/
/frontend/dist/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
